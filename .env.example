# Browser-safe Supabase connection (RLS remains mandatory)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-legacy-anon-key

# Server-only Supabase administration; never expose this key to the browser
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Separate 32+ byte random application-security secret. Domain-separated HMACs
# protect the short-lived handoff cookie, anonymous session, IP digest, and match
# idempotency key. Required in every hosted environment; do not reuse provider keys.
HANDOFF_TOKEN_SECRET=replace-with-a-random-32-byte-or-longer-secret

# Claude powers only the memory-only, non-clinical directory guide. Crisis text is
# stopped deterministically before the model client is initialized.
ANTHROPIC_API_KEY=your-anthropic-key

# Transactional email. Production must use a reviewed/covered sender and verified
# domain. Missing configuration returns a delivery failure and logs no recipient.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=
# SMTP_PASS=
# Set true only after the configured SMTP sender is covered by the required BAA.
# Sensitive treatment-information email never falls back to RESEND_API_KEY.
# SENSITIVE_EMAIL_BAA_APPROVED=false
# RESEND_API_KEY=
# EMAIL_FROM=Clear Bed Recovery <support@clearbedrecovery.com>

# Flat-fee facility subscriptions. Prices must be recurring Stripe Price IDs from
# the same live/test mode as STRIPE_SECRET_KEY. The webhook accepts the current and
# optional previous signing secret during deliberate rotation.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_STARTER_ANNUAL=price_...
# STRIPE_PRICE_GROWTH=price_...
# STRIPE_PRICE_GROWTH_ANNUAL=price_...
# STRIPE_PRICE_ANCHOR=price_...
# STRIPE_PRICE_ANCHOR_ANNUAL=price_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_WEBHOOK_SECRET_PREVIOUS=whsec_...

# Signed operational endpoints
# CRON_SECRET=
# REVALIDATE_SECRET=

# Canonical application origin
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Legacy Project-B PHI vault code remains disabled and unused by the Path-A
# connector release. Do not configure or enable it without a BAA, HIPAA add-on,
# security review, and qualified 42 CFR Part 2/EKRA counsel.
# HANDOFF_BAA_SIGNED=false
# VAULT_SUPABASE_URL=
# VAULT_SUPABASE_SERVICE_ROLE_KEY=
